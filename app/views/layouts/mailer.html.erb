<%
  font_stack = 'Helvetica, Arial, sans-serif'
  body_color = '#333333'
  header_bg = SiteSetting.header_background_color || '#000000'
  primary = SiteSetting.tertiary_color || '#0084F0'
  secondary = SiteSetting.secondary_color || '#00c896'
  site_name = SiteSetting.site_name || 'CinelarTV'
%>

<!-- Header -->
<table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="background: linear-gradient(135deg, <%= header_bg %> 0%, <%= header_bg %>cc 100%); border-bottom: 2px solid transparent; border-image: linear-gradient(90deg, <%= primary %>, <%= secondary %>) 1;">
  <tr>
    <td align="center" style="padding: 40px 30px;">
      <% if SiteSetting.site_logo.present? %>
        <%
          logo_url = SiteSetting.site_logo
          logo_url = "#{SiteSetting.site_url}#{logo_url}" unless logo_url.start_with?('http')
        %>
        <img src="<%= logo_url %>" alt="<%= site_name %>" style="max-width: 200px; max-height: 60px; object-fit: contain;" />
      <% else %>
        <h1 style="color: #ffffff; margin: 0; font-size: 28px; font-weight: 700; letter-spacing: -0.5px; font-family: <%= font_stack %>;"><%= site_name %></h1>
      <% end %>
    </td>
  </tr>
</table>

<!-- Body -->
<table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="font-family: <%= font_stack %>; color: <%= body_color %>; font-size: 16px; line-height: 1.7;">
  <tr>
    <td class="email-body" style="padding: 40px 30px;">
      <%= yield %>
    </td>
  </tr>
</table>

<!-- Footer -->
<table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="background: #f8f9fa; border-top: 1px solid #dee2e6; font-family: <%= font_stack %>;">
  <tr>
    <td align="center" style="padding: 30px; font-size: 13px; color: #6c757d;">
      <p style="margin: 0 0 10px 0;"><%= Time.current.year %> &copy; <%= site_name %>. All rights reserved.</p>
      <p style="margin: 0 0 10px 0;">This email was sent to <%= @recipient_email || 'you' %> because you have an account with <%= site_name %>.</p>
      <% if SiteSetting.site_url.present? %>
        <p style="margin: 0;"><a href="<%= SiteSetting.site_url %>" style="color: <%= primary %>; text-decoration: none; font-weight: 500;">Visit our website</a></p>
      <% end %>
    </td>
  </tr>
</table>
