<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="x-apple-disable-message-reformatting" />
    <!--[if !mso]><!-->
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <!--<![endif]-->
    <title><%= @subject || SiteSetting.site_name || "CinelarTV" %></title>

    <!--[if mso]>
    <style type="text/css">
      body, table, td, th, h1, h2, h3, h4, h5, h6, p, a, span {
        font-family: Helvetica, Arial, sans-serif !important;
      }
    </style>
    <![endif]-->

    <style>
      /* Reset */
      body, table, td, th, p, a, span {
        -webkit-text-size-adjust: 100%;
        -ms-text-size-adjust: 100%;
        mso-line-height-rule: exactly;
      }
      table, td {
        border-collapse: collapse !important;
        mso-table-lspace: 0pt;
        mso-table-rspace: 0pt;
      }
      img {
        border: 0;
        line-height: 100%;
        outline: none;
        text-decoration: none;
        -ms-interpolation-mode: bicubic;
        max-width: 100%;
        height: auto;
      }
      body {
        height: 100% !important;
        margin: 0 !important;
        padding: 0 !important;
        width: 100% !important;
        background-color: <%= SiteSetting.background_color || '#f8f9fa' %>;
      }

      /* Responsive */
      @media only screen and (max-width: 600px) {
        .email-wrapper { padding: 10px 5px !important; }
        .email-header { padding: 30px 20px !important; }
        .email-body { padding: 30px 20px !important; }
        .email-footer { padding: 20px !important; }
        .email-header h1 { font-size: 24px !important; }
        .email-button { display: block !important; width: 100% !important; text-align: center !important; }
      }

      /* Dark mode */
      @media (prefers-color-scheme: dark) {
        body { background-color: #1a1a1a !important; }
        .email-container { background-color: #2d2d2d !important; border-color: #404040 !important; }
        .email-body { color: #e9ecef !important; }
        .email-body p, .email-body h1, .email-body h2, .email-body h3, .email-body span { color: #e9ecef !important; }
        .email-footer { background: #2d2d2d !important; color: #adb5bd !important; border-color: #404040 !important; }
        .highlight-box { background: rgba(255,255,255,0.06) !important; border-color: rgba(255,255,255,0.12) !important; }
      }
    </style>
  </head>

  <% font_stack = SiteSetting.base_font_family || '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu, Cantarell, sans-serif' %>
  <% body_color = SiteSetting.body_text_color || '#333333' %>
  <% header_bg = SiteSetting.header_background_color || '#000000' %>
  <% primary = SiteSetting.tertiary_color || '#0084F0' %>
  <% secondary = SiteSetting.secondary_color || '#00c896' %>

  <body style="margin: 0; padding: 0; width: 100%; background-color: <%= SiteSetting.background_color || '#f8f9fa' %>; font-family: <%= font_stack %>; color: <%= body_color %>; font-size: 16px; line-height: 1.6;">
    <div class="email-wrapper" style="max-width: 600px; margin: 0 auto; padding: 20px 10px;">
      <div class="email-container" style="background-color: #ffffff; border-radius: 8px; box-shadow: 0 2px 12px rgba(0,0,0,0.08); overflow: hidden; border: 1px solid #e9ecef;">

        <!-- Header -->
        <div class="email-header" style="background: linear-gradient(135deg, <%= header_bg %> 0%, <%= header_bg %>cc 100%); padding: 40px 30px; text-align: center; position: relative; border-bottom: 2px solid transparent; border-image: linear-gradient(90deg, <%= primary %>, <%= secondary %>) 1;">
          <% if SiteSetting.site_logo.present? %>
            <%= image_tag SiteSetting.site_logo, alt: SiteSetting.site_name || "CinelarTV", style: "max-width: 200px; max-height: 60px; object-fit: contain; margin-bottom: 10px;" %>
          <% else %>
            <h1 style="color: <%= body_color %>; margin: 0; font-size: 28px; font-weight: 700; letter-spacing: -0.5px; font-family: <%= font_stack %>;"><%= SiteSetting.site_name || "CinelarTV" %></h1>
          <% end %>
        </div>

        <!-- Body -->
        <div class="email-body" style="padding: 40px 30px; color: <%= body_color %>; font-family: <%= font_stack %>; font-size: 16px; line-height: 1.7;">
          <%= yield %>
        </div>

        <!-- Footer -->
        <div class="email-footer" style="background: #f8f9fa; padding: 30px; text-align: center; font-size: 13px; color: #6c757d; border-top: 1px solid #dee2e6; font-family: <%= font_stack %>;">
          <p style="margin: 0 0 10px 0;"><%= Time.current.year %> &copy; <%= SiteSetting.site_name || "CinelarTV" %>. All rights reserved.</p>
          <p style="margin: 0 0 10px 0;">This email was sent to <%= @recipient_email || 'you' %> because you have an account with <%= SiteSetting.site_name || "CinelarTV" %>.</p>
          <% if SiteSetting.site_url.present? %>
            <p style="margin: 0;"><a href="<%= SiteSetting.site_url %>" style="color: <%= primary %>; text-decoration: none; font-weight: 500;">Visit our website</a></p>
          <% end %>
        </div>

      </div>
    </div>
  </body>
</html>
