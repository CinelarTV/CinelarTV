<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
      body {
        font-family: <%= SiteSetting.base_font_family || '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu, Cantarell, sans-serif' %>;
        line-height: 1.6;
        color: <%= SiteSetting.body_text_color || '#333333' %>;
        background-color: <%= SiteSetting.background_color || '#f4f4f4' %>;
        margin: 0;
        padding: 20px;
      }
      .email-container {
        max-width: 600px;
        margin: 0 auto;
        background-color: #ffffff;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        overflow: hidden;
      }
      .email-header {
        background-color: <%= SiteSetting.header_background_color || '#000000' %>;
        padding: 30px;
        text-align: center;
      }
      .email-header img {
        max-width: 200px;
        max-height: 60px;
        object-fit: contain;
      }
      .email-header h1 {
        color: <%= SiteSetting.body_text_color || '#ffffff' %>;
        margin: 0;
        font-size: 24px;
        font-weight: 600;
      }
      .email-body {
        padding: 30px;
      }
      .email-body p {
        margin: 0 0 16px 0;
      }
      .email-body a {
        color: <%= SiteSetting.tertiary_color || '#0084F0' %>;
        text-decoration: none;
        font-weight: 500;
      }
      .email-body a:hover {
        text-decoration: underline;
      }
      .email-button {
        display: inline-block;
        background-color: <%= SiteSetting.tertiary_color || '#0084F0' %>;
        color: <%= SiteSetting.body_text_color || '#ffffff' %>;
        padding: 12px 24px;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 500;
        margin: 20px 0;
      }
      .email-footer {
        background-color: #f8f9fa;
        padding: 20px;
        text-align: center;
        font-size: 12px;
        color: #666;
        border-top: 1px solid #e9ecef;
      }
      .email-footer a {
        color: <%= SiteSetting.tertiary_color || '#0084F0' %>;
        text-decoration: none;
      }
    </style>
  </head>

  <body>
    <div class="email-container">
      <div class="email-header">
        <% if SiteSetting.site_logo.present? %>
          <%= image_tag SiteSetting.site_logo, alt: SiteSetting.site_name || "CinelarTV" %>
        <% else %>
          <h1><%= SiteSetting.site_name || "CinelarTV" %></h1>
        <% end %>
      </div>
      <div class="email-body">
        <%= yield %>
      </div>
      <div class="email-footer">
        <p>&copy; <%= Time.current.year %> <%= SiteSetting.site_name || "CinelarTV" %>. All rights reserved.</p>
      </div>
    </div>
  </body>
</html>
