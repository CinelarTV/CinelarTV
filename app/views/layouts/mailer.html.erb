<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="x-apple-disable-message-reformatting" />
    <!--[if !mso]><!-->
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <!--<![endif]-->
    <title><%= @subject || SiteSetting.site_name || "CinelarTV" %></title>
    
    <!--[if mso]>
    <style type="text/css">
      body, table, td, th, h1, h2, h3, h4, h5, h6, p, a {
        font-family: Helvetica, Arial, sans-serif !important;
      }
    </style>
    <![endif]-->
    
    <style>
      /* Reset and base styles */
      body, table, td, th, p, a {
        -webkit-text-size-adjust: 100%;
        -ms-text-size-adjust: 100%;
        mso-line-height-rule: exactly;
      }
      
      table, td {
        border-collapse: collapse !important;
        mso-table-lspace: 0pt;
        mso-table-rspace: 0pt;
      }
      
      img {
        border: 0;
        line-height: 100%;
        outline: none;
        text-decoration: none;
        -ms-interpolation-mode: bicubic;
        max-width: 100%;
        height: auto;
      }
      
      body {
        height: 100% !important;
        margin: 0 !important;
        padding: 0 !important;
        width: 100% !important;
        background-color: <%= SiteSetting.background_color || '#f8f9fa' %>;
        font-family: <%= SiteSetting.base_font_family || '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu, Cantarell, sans-serif' %>;
        line-height: 1.6;
        color: <%= SiteSetting.body_text_color || '#333333' %>;
        font-size: 16px;
      }
      
      /* Main container */
      .email-wrapper {
        max-width: 600px;
        margin: 0 auto;
        padding: 20px 10px;
      }
      
      .email-container {
        background-color: #ffffff;
        border-radius: 8px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
        overflow: hidden;
        border: 1px solid #e9ecef;
      }
      
      /* Header styles */
      .email-header {
        background: linear-gradient(135deg, <%= SiteSetting.header_background_color || '#000000' %> 0%, <%= SiteSetting.header_background_color || '#1a1a1a' %> 100%);
        padding: 40px 30px;
        text-align: center;
        position: relative;
      }
      
      .email-header::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(90deg, <%= SiteSetting.tertiary_color || '#0084F0' %>, <%= SiteSetting.secondary_color || '#00c896' %>);
      }
      
      .email-header img {
        max-width: 200px;
        max-height: 60px;
        object-fit: contain;
        margin-bottom: 10px;
      }
      
      .email-header h1 {
        color: <%= SiteSetting.body_text_color || '#ffffff' %>;
        margin: 0;
        font-size: 28px;
        font-weight: 700;
        letter-spacing: -0.5px;
        text-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
      }
      
      /* Body styles */
      .email-body {
        padding: 40px 30px;
        color: <%= SiteSetting.body_text_color || '#333333' %>;
      }
      
      .email-body p {
        margin: 0 0 20px 0;
        line-height: 1.7;
      }
      
      .email-body h1, .email-body h2, .email-body h3 {
        margin-top: 30px;
        margin-bottom: 15px;
        font-weight: 600;
        line-height: 1.3;
      }
      
      .email-body h1 { font-size: 24px; }
      .email-body h2 { font-size: 20px; }
      .email-body h3 { font-size: 18px; }
      
      .email-body ul, .email-body ol {
        margin: 20px 0;
        padding-left: 25px;
      }
      
      .email-body li {
        margin-bottom: 8px;
      }
      
      .email-body a {
        color: <%= SiteSetting.tertiary_color || '#0084F0' %>;
        text-decoration: none;
        font-weight: 500;
        transition: color 0.2s ease;
      }
      
      .email-body a:hover {
        color: <%= SiteSetting.tertiary_color || '#0084F0' %>;
        text-decoration: underline;
      }
      
      /* Button styles */
      .email-button {
        display: inline-block;
        background: linear-gradient(135deg, <%= SiteSetting.tertiary_color || '#0084F0' %> 0%, <%= SiteSetting.tertiary_color || '#0066cc' %> 100%);
        color: <%= SiteSetting.body_text_color || '#ffffff' %> !important;
        padding: 14px 28px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        font-size: 16px;
        margin: 25px 0;
        box-shadow: 0 4px 12px rgba(<%= SiteSetting.tertiary_color || '#0084F0' %>, 0.3);
        transition: all 0.2s ease;
      }
      
      .email-button:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(<%= SiteSetting.tertiary_color || '#0084F0' %>, 0.4);
        text-decoration: none !important;
      }
      
      /* Footer styles */
      .email-footer {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        padding: 30px;
        text-align: center;
        font-size: 13px;
        color: #6c757d;
        border-top: 1px solid #dee2e6;
      }
      
      .email-footer p {
        margin: 0 0 10px 0;
      }
      
      .email-footer a {
        color: <%= SiteSetting.tertiary_color || '#0084F0' %>;
        text-decoration: none;
        font-weight: 500;
      }
      
      .email-footer a:hover {
        text-decoration: underline;
      }
      
      /* Responsive styles */
      @media only screen and (max-width: 600px) {
        .email-wrapper {
          padding: 10px 5px;
        }
        
        .email-header {
          padding: 30px 20px;
        }
        
        .email-body {
          padding: 30px 20px;
        }
        
        .email-footer {
          padding: 20px;
        }
        
        .email-header h1 {
          font-size: 24px;
        }
        
        .email-button {
          display: block;
          width: 100%;
          text-align: center;
        }
      }
      
      /* Dark mode support */
      @media (prefers-color-scheme: dark) {
        body {
          background-color: #1a1a1a !important;
        }
        
        .email-container {
          background-color: #2d2d2d !important;
          border-color: #404040 !important;
        }
        
        .email-body {
          color: #e9ecef !important;
        }
        
        .email-footer {
          background: linear-gradient(135deg, #2d2d2d 0%, #404040 100%) !important;
          color: #adb5bd !important;
          border-color: #404040 !important;
        }
      }
    </style>
  </head>

  <body>
    <div class="email-wrapper">
      <div class="email-container">
        <!-- Header -->
        <div class="email-header">
          <% if SiteSetting.site_logo.present? %>
            <%= image_tag SiteSetting.site_logo, alt: SiteSetting.site_name || "CinelarTV" %>
          <% else %>
            <h1><%= SiteSetting.site_name || "CinelarTV" %></h1>
          <% end %>
        </div>
        
        <!-- Body -->
        <div class="email-body">
          <%= yield %>
        </div>
        
        <!-- Footer -->
        <div class="email-footer">
          <p>&copy; <%= Time.current.year %> <%= SiteSetting.site_name || "CinelarTV" %>. All rights reserved.</p>
          <p>This email was sent to <%= @recipient_email || 'you' %> because you have an account with <%= SiteSetting.site_name || "CinelarTV" %>.</p>
          <% if SiteSetting.site_url.present? %>
            <p><a href="<%= SiteSetting.site_url %>">Visit our website</a></p>
          <% end %>
        </div>
      </div>
    </div>
  </body>
</html>
