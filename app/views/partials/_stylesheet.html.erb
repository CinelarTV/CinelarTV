<%= vite_stylesheet_tag 'application' %>
<%= render_external_stylesheets %>
<style id="app-theming"> 
    :root {
        --c-background-color: <%= SiteSetting.background_color %>;
        --c-body-text-color: <%= SiteSetting.body_text_color %>;
        --c-header-background-color: <%= SiteSetting.header_background_color %>;
        --c-font-family-base: <%= SiteSetting.base_font_family %>;
        --c-primary-color: <%= SiteSetting.primary_color %>;
        --c-secondary-color: <%= SiteSetting.secondary_color %>;
        --c-tertiary-color: <%= SiteSetting.tertiary_color %>;
        --c-quaternary-color: <%= SiteSetting.quaternary_color %>;
        --c-player-accent-color: <%= SiteSetting.player_accent_color %>;
        
        <%= generate_color_variants(SiteSetting.player_accent_color, "player-accent") %>
        <%= generate_color_variants(SiteSetting.primary_color, "primary") %>
        <%= generate_color_variants(SiteSetting.secondary_color, "secondary") %>
        <%= generate_color_variants(SiteSetting.tertiary_color, "tertiary") %>
        <%= generate_color_variants(SiteSetting.quaternary_color, "quaternary") %>

        /* Semantic surface tokens (dark theme) */
        --c-surface-0: rgba(255, 255, 255, 0.02);
        --c-surface-1: rgba(255, 255, 255, 0.03);
        --c-surface-2: rgba(255, 255, 255, 0.05);
        --c-surface-3: rgba(255, 255, 255, 0.08);
        --c-border-subtle: rgba(255, 255, 255, 0.06);
        --c-border-default: rgba(255, 255, 255, 0.08);
        --c-border-strong: rgba(255, 255, 255, 0.12);
        --c-text-primary: rgba(255, 255, 255, 0.92);
        --c-text-secondary: rgba(255, 255, 255, 0.62);
        --c-text-muted: rgba(255, 255, 255, 0.45);
        --c-text-faint: rgba(255, 255, 255, 0.35);
        --c-danger: #ff9494;
        --c-success: #1ec08a;
        --c-warning: #f09a5a;

      

    }
</style>
<% if !SiteSetting.custom_css.blank? %>
<style id="app-theming-custom">
    <%= SiteSetting.custom_css %>
</style>
<% end %>
