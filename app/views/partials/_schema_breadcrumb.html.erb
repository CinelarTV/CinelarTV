<%# BreadcrumbList schema - renders breadcrumb navigation for content pages %>
<% if defined?(@content) && @content.present? %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": <%= raw canonical_base.to_json %>
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Explore",
      "item": <%= raw canonical_url("/explore").to_json %>
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": <%= raw @content.title.to_json %>,
      "item": <%= raw canonical_url("/contents/#{@content.id}").to_json %>
    }
    <% if defined?(@episode) && @episode.present? %>
    ,
    {
      "@type": "ListItem",
      "position": 4,
      "name": <%= raw @episode.title.to_json %>,
      "item": <%= raw canonical_url("/watch/#{@content.id}/#{@episode.id}").to_json %>
    }
    <% end %>
  ]
}
</script>
<% end %>
